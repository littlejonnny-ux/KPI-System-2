{
  "model": "sonnet",
  "env": {
    "MAX_THINKING_TOKENS": "10000",
    "CLAUDE_CODE_SUBAGENT_MODEL": "haiku",
    "ENABLE_TOOL_SEARCH": "auto:5",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "50",
    "COMPACT_THRESHOLD": "50"
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "deny": [
      "Bash(npx supabase db reset*)",
      "Bash(npx supabase db execute*)",
      "Bash(supabase db reset*)",
      "Bash(supabase db execute*)",
      "Bash(psql*)",
      "Edit(.github/workflows/ci.yml)",
      "Edit(.github/workflows/*)",
      "Write(.github/workflows/ci.yml)",
      "Write(.github/workflows/*)"
    ],
    "allow": [
      "Bash(for dir:*)",
      "Bash(do touch:*)",
      "Bash(done)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(find .claude -name \".gitkeep\" -delete)",
      "Bash(git mv:*)",
      "Bash(claude mcp:*)",
      "Bash(node -e \"require\\(''./.claude/hooks/scripts/pre-compact.js''\\)\")",
      "Bash(node -e \"require\\(''./.claude/hooks/scripts/suggest-compact.js''\\)\")",
      "Bash(node -e \"require\\(''./.claude/hooks/scripts/session-start.js''\\)\")",
      "Bash(node -e \"require\\(''./.claude/hooks/scripts/session-end.js''\\)\")",
      "Bash(npx playwright:*)",
      "Bash(npm install:*)",
      "Bash(node .claude/hooks/scripts/compliance-monitor.js)",
      "Bash(npx supabase migration new:*)",
      "Bash(npx supabase migration list*)",
      "Bash(npx supabase migration repair:*)",
      "Bash(npx supabase db push --dry-run*)",
      "Bash(npx supabase db push*)",
      "Bash(npx supabase db diff*)",
      "Bash(npx supabase db dump*)",
      "Bash(npx supabase status*)",
      "Bash(npx supabase start*)",
      "Bash(npx supabase stop*)",
      "Bash(npx supabase login*)",
      "Bash(npx supabase link*)",
      "Bash(node scripts/migration-safety-analyzer.mjs*)"
    ]
  }
}
